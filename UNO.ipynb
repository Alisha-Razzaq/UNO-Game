    "def get_valid_moves(hand, top):\n",
    "    if top is None:\n",
    "        return []\n",
    "    return [c for c in hand if c.color == top.color or c.number == top.number]\n",
    "\n",
    "def apply_move(hand, move, deck, current_top):\n",
    "    if move is None:\n",
    "        if deck:\n",
    "            hand.append(deck.pop())\n",
    "        return current_top, False\n",
    "\n",
    "    hand.remove(move)\n",
    "    return move, move.is_skip()\n",
    "\n",
    "class GameState:\n",
    "    def __init__(self, p1, p2, p3, top, deck, turn):\n",
    "        self.p1 = p1\n",
    "        self.p2 = p2\n",
    "        self.p3 = p3\n",
    "        self.top = top\n",
    "        self.deck = deck\n",
    "        self.turn = turn\n",
    "\n",
    "def clone(state):\n",
    "    return GameState(\n",
    "        state.p1.copy(),\n",
    "        state.p2.copy(),\n",
    "        state.p3.copy(),\n",
    "        state.top,\n",
    "        state.deck.copy(),\n",
    "        state.turn\n",
    "    )"
   ]
